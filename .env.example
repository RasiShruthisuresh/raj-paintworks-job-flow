# Server port. Railway sets this automatically at runtime - leave unset in production.
PORT=3001

# Origin allowed to call the API via CORS. Only matters for local dev, where the
# Vite client (5173) and Express server (3001) run on different origins; in
# production the built frontend is served by the same Express app/port, so
# these are same-origin requests and CORS doesn't apply. Set to your deployed
# origin anyway for completeness/documentation.
CORS_ORIGIN=http://localhost:5173

# Absolute path to the SQLite database file. Optional locally (defaults to
# server/data/app.db). Set this to a mounted Railway volume path (e.g.
# /data/app.db) in production so the database survives redeploys.
DB_PATH=

# Base URL the frontend uses to call the API. Only needed for local dev, where
# frontend and backend run on different ports. Leave unset in production -
# the frontend and API share the same origin there, so relative paths work.
VITE_API_BASE_URL=http://localhost:3001
